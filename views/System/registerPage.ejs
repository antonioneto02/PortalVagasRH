<!DOCTYPE html>
<html>
<head>
  <title>Cadastro - Portal Vagas RH</title>
  <%- include('headIncludes.ejs') %>
</head>
<body style="min-height:100vh; display:flex; align-items:center; justify-content:center; background-image:url('/css/Background.png'); background-size:cover; background-position:center; background-repeat:no-repeat; padding:16px; box-sizing:border-box;">
  <div style="width:100%; max-width:480px;">
        <div class="card">
          <div class="card-header text-center" style="background: linear-gradient(135deg, #2B286F 100%); border: none;">
            <div class="d-flex align-items-center justify-content-center mb-2">
              <img src="/css/logo-cini.png" alt="Cini" style="height: 40px; margin-right: 15px;">
              <h2 class="text-white mb-0">Cadastro de Acesso</h2>
            </div>
            <h6 class="text-white mb-0">Crie seu acesso para visualizar vagas externas.</h6>

            <% if (error === 'campos_obrigatorios') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Preencha todos os campos obrigatórios.</strong>
              </div>
            <% } else if (error === 'usuario_ja_existe') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Este nome de usuário já está em uso.</strong>
              </div>
            <% } else if (error === 'email_invalido') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Informe um e-mail válido.</strong>
              </div>
            <% } else if (error === 'email_obrigatorio') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Informe um e-mail para receber o código de verificação.</strong>
              </div>
            <% } else if (error === 'senha_fraca') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Senha fraca. Revise os critérios de segurança.</strong>
              </div>
            <% } else if (error === 'usuario_invalido') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Usuário inválido.</strong> Use apenas letras, números, ponto, hífen ou sublinhado (3 a 100 caracteres).
              </div>
            <% } else if (error === 'too_many_attempts') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Muitas tentativas de cadastro.</strong> Aguarde alguns minutos e tente novamente.
              </div>
            <% } else if (error === 'sessao_invalida') { %>
              <div id="errorAlert" class="alert alert-warning mt-2" role="alert" style="border-left: 4px solid #ffc107;">
                <strong>Sessão de segurança expirada.</strong> Recarregue a página e tente novamente.
              </div>
            <% } else if (error === 'erro_envio_otp') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Não foi possível enviar o código de verificação por e-mail.</strong> Verifique as configurações de SMTP.
              </div>
            <% } else if (error === 'otp_expirado') { %>
              <div id="errorAlert" class="alert alert-warning mt-2" role="alert" style="border-left: 4px solid #ffc107;">
                <strong>Seu processo de verificação expirou.</strong> Inicie o cadastro novamente.
              </div>
            <% } else if (error === 'otp_tentativas_excedidas') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Tentativas excedidas.</strong> Inicie o cadastro novamente.
              </div>
            <% } else if (error === 'erro_interno') { %>
              <div id="errorAlert" class="alert alert-danger mt-2" role="alert" style="border-left: 4px solid #dc3545;">
                <strong>Erro interno. Tente novamente.</strong>
              </div>
            <% } %>
          </div>

          <div class="card-body">
            <form method="POST" action="/register">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="form-group mb-3">
                <label for="nome">Nome Completo <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="nome" name="nome" required autocomplete="name">
                <div id="usernamePreview" class="mt-1" style="font-size:0.85rem; display:none;">
                  Seu usuário será: <strong id="usernamePreviewValue"></strong>
                </div>
              </div>

              <div class="form-group mb-3">
                <label for="email">E-mail <span class="text-danger">*</span></label>
                <input type="email" class="form-control" id="email" name="email" autocomplete="email" maxlength="200" required>
                <div id="emailFeedback" class="text-danger mt-1" style="display:none; font-size:0.85rem;">Informe um e-mail válido.</div>
              </div>

              <div class="form-group mb-3">
                <label for="telefone">Telefone</label>
                <input type="text" class="form-control" id="telefone" name="telefone" placeholder="(00) 00000-0000" autocomplete="tel" inputmode="numeric" maxlength="15">
              </div>

              <div class="form-group mb-3">
                <label for="password">Senha <span class="text-danger">*</span></label>
                <div style="position: relative;">
                  <input type="password" class="form-control" id="password" name="password" required style="padding-right: 45px;" autocomplete="new-password" minlength="8">
                  <button class="btn" type="button" id="togglePw" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); z-index: 10; border: none; background: none; padding: 0; color: #6c757d;">
                    <i class="fas fa-eye" id="togglePwIcon"></i>
                  </button>
                </div>
                <div id="pwRules" class="mt-2" style="font-size:0.85rem; line-height:1.4; display:none;">
                  <div id="ruleLen" class="text-danger">Pelo menos 8 caracteres</div>
                  <div id="ruleUpper" class="text-danger">Uma letra maiúscula</div>
                  <div id="ruleLower" class="text-danger">Uma letra minúscula</div>
                  <div id="ruleNumber" class="text-danger">Um número</div>
                  <div id="ruleSpecial" class="text-danger">Um caractere especial</div>
                </div>
              </div>

              <div class="form-group mb-4">
                <label for="confirmPassword">Confirmar Senha <span class="text-danger">*</span></label>
                <input type="password" class="form-control" id="confirmPassword" required>
                <div id="pwMismatch" class="text-danger mt-1" style="display:none; font-size:0.85rem;">
                  As senhas não coincidem.
                </div>
              </div>

              <div class="text-center mt-3">
                <button type="submit" id="submitBtn" class="btn" style="background: linear-gradient(135deg, #2B286F 100%); border: none; color: white; padding: 10px 30px; font-weight: 600;">
                  <i class="fas fa-user-plus me-2"></i>Cadastrar
                </button>
              </div>
              <div class="text-center mt-3">
                <small class="text-muted">
                  Já possui cadastro? <a href="/login" style="color: #2B286F; font-weight: 600;">Faça login</a>
                </small>
              </div>
            </form>
          </div>
        </div>
  </div>

  <style>
    @media (max-width: 575px) {
      body { padding: 12px !important; }
      .card { box-shadow: 0 8px 32px rgba(0,0,0,0.35); }
      .card-header { padding: 1rem; }
      .card-header h2 { font-size: 1.25rem; }
      .card-body { padding: 1rem; }
      .container { padding: 0 !important; }
    }
  </style>
  <script>
    const nomeField = document.getElementById('nome');
    const usernamePreview = document.getElementById('usernamePreview');
    const usernamePreviewValue = document.getElementById('usernamePreviewValue');
    const emailField = document.getElementById('email');
    const emailFeedback = document.getElementById('emailFeedback');
    const telefoneField = document.getElementById('telefone');
    const passwordField = document.getElementById('password');
    const pwRulesBox = document.getElementById('pwRules');
    const submitBtn = document.getElementById('submitBtn');

    document.getElementById('togglePw').addEventListener('click', function() {
      const pw = document.getElementById('password');
      const icon = document.getElementById('togglePwIcon');
      if (pw.type === 'password') { pw.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
      else { pw.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
    });

    const passwordRules = {
      len: document.getElementById('ruleLen'),
      upper: document.getElementById('ruleUpper'),
      lower: document.getElementById('ruleLower'),
      number: document.getElementById('ruleNumber'),
      special: document.getElementById('ruleSpecial'),
    };

    function setRuleState(el, ok) {
      el.classList.toggle('text-success', ok);
      el.classList.toggle('text-danger', !ok);
    }

    function getPasswordChecks(value) {
      return {
        len: value.length >= 8,
        upper: /[A-Z]/.test(value),
        lower: /[a-z]/.test(value),
        number: /\d/.test(value),
        special: /[^A-Za-z\d]/.test(value),
      };
    }

    function isPasswordStrong(value) {
      const checks = getPasswordChecks(value);
      return checks.len && checks.upper && checks.lower && checks.number && checks.special;
    }

    function validateEmailField() {
      const email = emailField.value.trim();
      if (!email) {
        emailFeedback.style.display = 'none';
        emailField.setCustomValidity('');
        return true;
      }
      const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      emailFeedback.style.display = ok ? 'none' : 'block';
      emailField.setCustomValidity(ok ? '' : 'Informe um e-mail válido.');
      return ok;
    }

    function applyPhoneMask(value) {
      const digits = value.replace(/\D/g, '').slice(0, 11);
      if (digits.length <= 10) {
        return digits
          .replace(/(\d{2})(\d)/, '($1) $2')
          .replace(/(\d{4})(\d)/, '$1-$2');
      }
      return digits
        .replace(/(\d{2})(\d)/, '($1) $2')
        .replace(/(\d{5})(\d)/, '$1-$2');
    }

    function generateUsernamePreview(nome) {
      const parts = nome
        .trim()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9\s]/g, '')
        .trim()
        .split(/\s+/)
        .filter(Boolean);

      if (parts.length === 0) return '';
      if (parts.length === 1) return parts[0];
      return `${parts[0]}.${parts[1]}`;
    }

    nomeField.addEventListener('input', function() {
      const preview = generateUsernamePreview(this.value);
      if (preview.length >= 3) {
        usernamePreviewValue.textContent = preview;
        usernamePreview.style.display = 'block';
      } else {
        usernamePreview.style.display = 'none';
      }
    });

    passwordField.addEventListener('input', function() {
      const checks = getPasswordChecks(this.value);
      setRuleState(passwordRules.len, checks.len);
      setRuleState(passwordRules.upper, checks.upper);
      setRuleState(passwordRules.lower, checks.lower);
      setRuleState(passwordRules.number, checks.number);
      setRuleState(passwordRules.special, checks.special);
    });

    passwordField.addEventListener('focus', function() {
      pwRulesBox.style.display = 'block';
    });

    passwordField.addEventListener('blur', function() {
      pwRulesBox.style.display = 'none';
    });

    emailField.addEventListener('input', validateEmailField);

    telefoneField.addEventListener('input', function() {
      this.value = applyPhoneMask(this.value);
    });

    document.querySelector('form').addEventListener('submit', function(e) {
      const pw = passwordField.value;
      const confirm = document.getElementById('confirmPassword').value;
      const strongPw = isPasswordStrong(pw);
      const validEmail = validateEmailField();

      if (!strongPw) {
        e.preventDefault();
        passwordField.focus();
        return;
      }

      if (!validEmail) {
        e.preventDefault();
        emailField.focus();
        return;
      }

      if (pw !== confirm) {
        e.preventDefault();
        document.getElementById('pwMismatch').style.display = 'block';
        submitBtn.disabled = false;
      }
    });

    document.getElementById('confirmPassword').addEventListener('input', function() {
      const pw = document.getElementById('password').value;
      document.getElementById('pwMismatch').style.display = (this.value && this.value !== pw) ? 'block' : 'none';
    });
  </script>
</body>
</html>
