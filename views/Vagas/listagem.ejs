<!DOCTYPE html>
<html>
<head>
  <title>Vagas RH - Portal Cini</title>
  <%- include('../System/headIncludes.ejs') %>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg">
    <a class="navbar-brand" href="/vagas">
      <div class="navbar-logo-container">
        <img src="/css/logo-cini.png" alt="Cini" class="navbar-logo">
        <div class="navbar-brand-text">
          <span class="navbar-subtitle">Portal Vagas RH</span>
        </div>
      </div>
    </a>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav mr-auto"></ul>
      <div class="user-menu">
        <div class="user-avatar dropdown">
          <a href="#" class="user-avatar-link" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="fas fa-user"></i>
          </a>
          <div class="dropdown-menu user-dropdown" aria-labelledby="userDropdown" style="right: 0; left: auto; min-width: 220px;">
            <div class="dropdown-header text-center" style="padding: 15px;">
              <i class="fas fa-user-circle fa-2x" style="color: #2B286F;"></i>
              <div style="margin-top: 8px; font-weight: 600; color: #333;"><%= username %></div>
              <% if (isProtheus && protheusId) { %>
                <div><small class="text-muted"><i class="fas fa-id-card"></i> ID Protheus: <strong><%= protheusId %></strong></small></div>
              <% } else { %>
                <div><small class="text-muted"><i class="fas fa-user"></i> Acesso Externo</small></div>
              <% } %>
            </div>
            <div class="dropdown-divider"></div>
            <a class="dropdown-item" href="/logout">
              <i class="fas fa-sign-out-alt"></i> Logout
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Conteúdo -->
  <div class="container-fluid mt-4">
    <div class="row justify-content-center">
      <div class="col-lg-12">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <h4 class="mb-0">
                <i class="fas fa-briefcase me-2" style="color: #2B286F;"></i>
                Vagas
                <% if (!isProtheus) { %>
                  <span class="badge" style="background: #17a2b8; font-size: 0.7rem; vertical-align: middle; padding: 4px 8px; border-radius: 4px;">Somente Externas</span>
                <% } %>
              </h4>
            </div>
            <% if (podeCadastrar) { %>
              <button class="btn btn-primary" id="btnNovaVaga" style="background: linear-gradient(135deg, #2B286F 100%); border: none;">
                <i class="fas fa-plus me-1"></i> Nova Vaga
              </button>
            <% } %>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table id="tblVagas" class="display table table-striped table-hover" style="width:100%">
                <thead>
                  <tr>
                    <th>Função</th>
                    <th>Tipo</th>
                    <th>Status</th>
                    <th>Setor</th>
                    <th>Solicitante</th>
                    <th>Classificação</th>
                    <th>SLA (dias)</th>
                    <th>Candidatos</th>
                    <th>Entrevistas</th>
                    <th>Abertura</th>
                    <th>Prazo</th>
                    <th>Empresa</th>
                    <th>Notebook</th>
                    <th>Celular</th>
                    <th>Requisitos</th>
                  </tr>
                </thead>
                <tbody>
                  <% vagas.forEach(v => { %>
                    <tr>
                      <td><%= v.FUNCAO %></td>
                      <td>
                        <span class="badge" style="background: <%= v.TIPO_VAGA === 'INTERNA' ? '#2B286F' : '#D11F3F' %>; padding: 4px 8px; border-radius: 4px; color: white; font-size: 0.75rem;">
                          <%= v.TIPO_VAGA %>
                        </span>
                      </td>
                      <td>
                        <span class="badge" style="
                          background: <%= v.STATUS === 'ABERTA' ? '#27ae60' : v.STATUS === 'FECHADA' ? '#6c757d' : '#e67e22' %>;
                          padding: 4px 8px; border-radius: 4px; color: white; font-size: 0.75rem;">
                          <%= v.STATUS %>
                        </span>
                      </td>
                      <td><%= v.SETOR || '-' %></td>
                      <td><%= v.SOLICITANTE || '-' %></td>
                      <td>
                        <% if (v.CLASSIFICACAO) { %>
                          <span class="badge" style="
                            background: <%= v.CLASSIFICACAO === 'ALTA' ? '#e74c3c' : v.CLASSIFICACAO === 'MEDIA' ? '#f39c12' : '#27ae60' %>;
                            padding: 4px 8px; border-radius: 4px; color: white; font-size: 0.75rem;">
                            <%= v.CLASSIFICACAO %>
                          </span>
                        <% } else { %>-<% } %>
                      </td>
                      <td><%= v.SLA_DIAS !== null ? v.SLA_DIAS : '-' %></td>
                      <td><%= v.CANDIDATOS !== null ? v.CANDIDATOS : 0 %></td>
                      <td><%= v.ENTREVISTAS !== null ? v.ENTREVISTAS : 0 %></td>
                      <td><%= v.DATA_ABERTURA || '-' %></td>
                      <td><%= v.PRAZO_CONTRATACAO || '-' %></td>
                      <td><%= v.EMPRESA || '-' %></td>
                      <td>
                        <span style="color: <%= v.NOTEBOOK === 'SIM' ? '#27ae60' : '#e74c3c' %>; font-weight: 600;">
                          <i class="fas fa-<%= v.NOTEBOOK === 'SIM' ? 'check' : 'times' %>"></i>
                        </span>
                      </td>
                      <td>
                        <span style="color: <%= v.CELULAR === 'SIM' ? '#27ae60' : '#e74c3c' %>; font-weight: 600;">
                          <i class="fas fa-<%= v.CELULAR === 'SIM' ? 'check' : 'times' %>"></i>
                        </span>
                      </td>
                      <td style="max-width: 300px; white-space: normal; font-size: 0.82rem;"><%= v.REQUISITOS_VAGA || '-' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Nova Vaga -->
  <% if (podeCadastrar) { %>
  <div class="modal fade" id="modalNovaVaga" tabindex="-1" role="dialog" aria-labelledby="modalNovaVagaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header" style="background: linear-gradient(135deg, #2B286F 100%); color: white;">
          <h5 class="modal-title" id="modalNovaVagaLabel">
            <i class="fas fa-plus-circle me-2"></i>Cadastrar Nova Vaga
          </h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Fechar" style="color: white; opacity: 1;">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="formNovaVaga">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label>Função <span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="funcao" required>
              </div>
              <div class="col-md-3 mb-3">
                <label>Data Abertura <span class="text-danger">*</span></label>
                <input type="date" class="form-control" name="data_abertura" required>
              </div>
              <div class="col-md-3 mb-3">
                <label>Tipo de Vaga <span class="text-danger">*</span></label>
                <select class="form-control" name="tipo_vaga" required>
                  <option value="">Selecione...</option>
                  <option value="INTERNA">INTERNA</option>
                  <option value="EXTERNA">EXTERNA</option>
                </select>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label>Solicitante</label>
                <input type="text" class="form-control" name="solicitante">
              </div>
              <div class="col-md-6 mb-3">
                <label>Setor</label>
                <input type="text" class="form-control" name="setor">
              </div>
            </div>
            <div class="row">
              <div class="col-md-3 mb-3">
                <label>Notebook</label>
                <select class="form-control" name="notebook">
                  <option value="NAO">NÃO</option>
                  <option value="SIM">SIM</option>
                </select>
              </div>
              <div class="col-md-3 mb-3">
                <label>Celular</label>
                <select class="form-control" name="celular">
                  <option value="NAO">NÃO</option>
                  <option value="SIM">SIM</option>
                </select>
              </div>
              <div class="col-md-3 mb-3">
                <label>SLA (dias)</label>
                <input type="number" class="form-control" name="sla_dias" min="1">
              </div>
              <div class="col-md-3 mb-3">
                <label>Classificação</label>
                <select class="form-control" name="classificacao">
                  <option value="">Selecione...</option>
                  <option value="ALTA">ALTA</option>
                  <option value="MEDIA">MEDIA</option>
                  <option value="BAIXA">BAIXA</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label>Requisitos da Vaga</label>
              <textarea class="form-control" name="requisitos_vaga" rows="4" placeholder="Descreva os requisitos..."></textarea>
            </div>
            <div class="row">
              <div class="col-md-4 mb-3">
                <label>Candidatos</label>
                <input type="number" class="form-control" name="candidatos" value="0" min="0">
              </div>
              <div class="col-md-4 mb-3">
                <label>Entrevistas</label>
                <input type="number" class="form-control" name="entrevistas" value="0" min="0">
              </div>
              <div class="col-md-4 mb-3">
                <label>Matrícula</label>
                <input type="text" class="form-control" name="matricula">
              </div>
            </div>
            <div class="row">
              <div class="col-md-4 mb-3">
                <label>Prazo Contratação</label>
                <input type="date" class="form-control" name="prazo_contratacao">
              </div>
              <div class="col-md-4 mb-3">
                <label>Data Contratação</label>
                <input type="date" class="form-control" name="dt_contratacao">
              </div>
              <div class="col-md-4 mb-3">
                <label>Status</label>
                <select class="form-control" name="status">
                  <option value="ABERTA">ABERTA</option>
                  <option value="FECHADA">FECHADA</option>
                  <option value="ATRASADA">ATRASADA</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label>Empresa</label>
              <input type="text" class="form-control" name="empresa">
            </div>
            <div id="formError" class="alert alert-danger" style="display:none;"></div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary" id="btnSalvarVaga" style="background: linear-gradient(135deg, #2B286F 100%); border: none;">
            <span id="savingSpinner" class="spinner-border spinner-border-sm me-1" style="display:none;" role="status"></span>
            <i class="fas fa-save me-1" id="saveIcon"></i>Salvar Vaga
          </button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <style>
    .navbar {
      background: linear-gradient(135deg, #2B286F 0%, #1e1f5c 100%) !important;
      border-bottom: 2.5px solid #D11F3F;
      padding: 0.3rem 1rem;
    }
    .navbar-brand { color: white !important; font-weight: 600; }
    .navbar-logo { height: 40px; margin-right: 10px; }
    .navbar-subtitle { font-size: 0.85rem; color: rgba(255,255,255,0.85); display: block; }
    .navbar-logo-container { display: flex; align-items: center; }
    .user-avatar-link {
      display: flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 50%;
      background: rgba(255,255,255,0.2); color: white; text-decoration: none;
    }
    .user-avatar-link:hover { background: rgba(255,255,255,0.3); color: white; }
    .user-menu { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); }
    .user-dropdown { right: 0 !important; left: auto !important; }
    .card-header { background: linear-gradient(135deg, #2B286F 0%, #1e1f5c 100%); color: white; }
    .card-header h4 { color: white; }
    .me-1 { margin-right: 0.25rem !important; }
    .me-2 { margin-right: 0.5rem !important; }
    .mt-4 { margin-top: 1.5rem !important; }
    .modal-header .close:hover { opacity: 0.8; }
    #tblVagas td { vertical-align: middle; }
  </style>

  <script>
    $(document).ready(function () {
      $('#tblVagas').DataTable({
        language: {
          url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json'
        },
        dom: 'Bfrtip',
        buttons: [
          {
            extend: 'excelHtml5',
            text: '<i class="fas fa-file-excel"></i> Exportar Excel',
            className: 'btn btn-success btn-sm',
            title: 'Vagas RH'
          }
        ],
        pageLength: 25,
        order: [[9, 'desc']],
        columnDefs: [
          { targets: [14], orderable: false }
        ]
      });

      // Dropdown do usuário
      $('#userDropdown').on('click', function(e) {
        e.preventDefault();
        $(this).next('.dropdown-menu').toggleClass('show');
      });
      $(document).on('click', function(e) {
        if (!$(e.target).closest('.user-avatar').length) {
          $('.user-dropdown').removeClass('show');
        }
      });

      <% if (podeCadastrar) { %>
      $('#btnNovaVaga').on('click', function() {
        $('#formNovaVaga')[0].reset();
        $('#formError').hide();
        const today = new Date().toISOString().split('T')[0];
        $('[name="data_abertura"]').val(today);
        $('#modalNovaVaga').modal('show');
      });

      $('#btnSalvarVaga').on('click', function() {
        const form = document.getElementById('formNovaVaga');
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const data = {};
        $(form).serializeArray().forEach(f => data[f.name] = f.value);

        $('#savingSpinner').show();
        $('#saveIcon').hide();
        $('#btnSalvarVaga').prop('disabled', true);

        $.ajax({
          url: '/vagas',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify(data),
          success: function() {
            $('#modalNovaVaga').modal('hide');
            location.reload();
          },
          error: function(xhr) {
            const msg = xhr.responseJSON?.error || 'Erro ao salvar. Tente novamente.';
            $('#formError').text(msg).show();
            $('#savingSpinner').hide();
            $('#saveIcon').show();
            $('#btnSalvarVaga').prop('disabled', false);
          }
        });
      });
      <% } %>
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
