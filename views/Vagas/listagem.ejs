<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Vagas RH - Portal Cini</title>
  <%- include('../System/headIncludes.ejs') %>
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <style>
    .modal .select2-container { width: 100% !important; }
    .select2-container--default .select2-selection--single {
      height: calc(1.5em + 0.75rem + 2px);
      border: 1px solid #ced4da;
      border-radius: 0.25rem;
      padding: 0.375rem 0.75rem;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered { line-height:1.5; padding:0; color:#495057; }
    .select2-container--default .select2-selection--single .select2-selection__arrow { height: calc(1.5em + 0.75rem + 2px); }
    .select2-dropdown { z-index: 9999; }

    #tblVagas td, #tblVagas th { padding: .35rem .5rem; line-height:1.15; vertical-align: middle; }
    .no-wrap { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:180px; }
    .req-cell { max-width:280px; font-size:.82rem; }

    .clickable-cell {
      cursor: pointer;
      display: flex;
      align-items: center;
      width: 100%;
      height: 100%;
      box-sizing: border-box;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding: 2px 6px;
    }
    .clickable-cell:hover { background: rgba(0,0,0,0.05); border-radius: 4px; }
    td .cell-inner { height: 100%; width: 100%; display: flex; align-items: center; }

    .vagas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }
    .vaga-card {
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff 0%, #fbfbff 100%);
      box-shadow: 0 6px 14px rgba(43, 40, 111, 0.08);
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: .55rem;
      min-height: 260px;
      cursor: pointer;
      transition: transform .15s ease, box-shadow .15s ease;
    }
    .vaga-card:hover { transform: translateY(-2px); box-shadow: 0 10px 18px rgba(43, 40, 111, 0.12); }
    .vaga-card .head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: .6rem;
    }
    .vaga-card h5 {
      margin: 0;
      font-size: 1.02rem;
      color: #1f2937;
      font-weight: 700;
      line-height: 1.25;
    }
    .vaga-meta {
      font-size: .86rem;
      color: #4b5563;
      display: flex;
      flex-wrap: wrap;
      gap: .45rem .8rem;
    }
    .vaga-requisitos {
      font-size: .88rem;
      color: #374151;
      border-top: 1px dashed #d1d5db;
      padding-top: .55rem;
      margin-top: .1rem;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
    }

    .me-1 { margin-right:.25rem!important; }
    .me-2 { margin-right:.5rem!important; }
    .dt-filtros select { font-size:.82rem; height:calc(1.5em + .5rem + 2px); display:inline-block; width:auto; min-width:110px; }
    .curriculo-preview-card { gap: .5rem; }
    .curriculo-preview-meta { min-width: 0; flex: 1; }
    .curriculo-preview-meta #curriculoNome { word-break: break-word; line-height: 1.2; }
    #removerCurriculo { flex-shrink: 0; margin-left: .5rem !important; }
    .btn-curriculo-acao { min-width: 84px; }
  </style>
</head>
<body>
<div class="layout-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <h1>
          <i class="bi bi-briefcase me-2"></i>Vagas
          <% if (!isAdmin) { %>
            <small style="font-size:0.72rem; background:#17a2b8; border-radius:4px; padding:2px 7px; vertical-align:middle;">Área do Candidato</small>
          <% } %>
        </h1>
      </div>
      <div class="topbar-right">
        <span><i class="bi bi-person-circle me-1"></i><%= username %></span>
        <a href="/logout"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
      </div>
    </div>

    <div class="content">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="mb-0"><i class="fas fa-briefcase me-2"></i>Vagas</h4>
          <% if (isAdmin) { %>
            <button class="btn btn-sm" id="btnNovaVaga" style="background:rgba(255,255,255,0.18); border:1px solid rgba(255,255,255,0.4); color:white;">
              <i class="fas fa-plus me-1"></i> Nova Vaga
            </button>
          <% } %>
        </div>

        <div class="card-body">
          <div id="candSuccessAlert" class="alert alert-success" style="display:none;">
            <i class="fas fa-check-circle me-1"></i>Candidatura enviada com sucesso!
          </div>
          <% if (isAdmin) { %>
            <div class="table-responsive">
              <table id="tblVagas" class="display table table-striped table-hover" style="width:100%">
                <thead>
                  <tr>
                    <th>Função</th><th>Tipo</th><th>Status</th><th class="text-center">Setor</th><th>Solicitante</th>
                    <th>Classificação</th><th>SLA</th><th>Candidatos</th><th>Entrevistas</th>
                    <th>Abertura</th><th>Prazo</th><th class="text-center">Empresa</th><th class="text-center">Notebook</th><th class="text-center">Celular</th><th>Requisitos</th><th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% vagas.forEach(v => { %>
                    <tr>
                      <td class="no-wrap"><div class="cell-inner clickable-cell" title="<%= v.FUNCAO %>" data-toggle="tooltip"><%= v.FUNCAO %></div></td>
                      <td class="no-wrap" title="<%= v.TIPO_VAGA %>" data-toggle="tooltip"><span class="badge" style="background:<%= v.TIPO_VAGA==='INTERNA'?'#2B286F':'#D11F3F' %>;padding:3px 7px;border-radius:4px;color:white;font-size:.74rem;"><%= v.TIPO_VAGA %></span></td>
                      <td class="no-wrap" title="<%= v.STATUS %>" data-toggle="tooltip"><span class="badge" style="background:<%= v.STATUS==='ABERTA'?'#27ae60':v.STATUS==='FECHADA'?'#6c757d':'#e67e22' %>;padding:3px 7px;border-radius:4px;color:white;font-size:.74rem;"><%= v.STATUS %></span></td>
                      <td class="no-wrap text-center"><div class="cell-inner clickable-cell text-center" title="<%= v.SETOR||'-' %>" data-toggle="tooltip"><%= v.SETOR||'-' %></div></td>
                      <td class="no-wrap"><div class="cell-inner clickable-cell" title="<%= v.SOLICITANTE||'-' %>" data-toggle="tooltip"><%= v.SOLICITANTE||'-' %></div></td>
                      <td class="text-center"><% if(v.CLASSIFICACAO){ %><span class="badge" style="background:<%= v.CLASSIFICACAO==='ALTA'?'#e74c3c':v.CLASSIFICACAO==='MEDIA'?'#f39c12':'#27ae60' %>;padding:3px 7px;border-radius:4px;color:white;font-size:.74rem;"><%= v.CLASSIFICACAO %></span><% } else { %>-<% } %></td>
                      <td class="text-center" title="<%= v.SLA_DIAS!==null?v.SLA_DIAS:'-' %>" data-toggle="tooltip"><%= v.SLA_DIAS!==null?v.SLA_DIAS:'-' %></td>
                      <td class="text-center" title="<%= v.CANDIDATOS!==null?v.CANDIDATOS:0 %>" data-toggle="tooltip"><%= v.CANDIDATOS!==null?v.CANDIDATOS:0 %></td>
                      <td class="text-center" title="<%= v.ENTREVISTAS!==null?v.ENTREVISTAS:0 %>" data-toggle="tooltip"><%= v.ENTREVISTAS!==null?v.ENTREVISTAS:0 %></td>
                      <td title="<%= v.DATA_ABERTURA||'-' %>" data-toggle="tooltip"><%= v.DATA_ABERTURA||'-' %></td>
                      <td title="<%= v.PRAZO_CONTRATACAO||'-' %>" data-toggle="tooltip"><%= v.PRAZO_CONTRATACAO||'-' %></td>
                      <td class="text-center"><div class="cell-inner clickable-cell text-center" title="<%= v.EMPRESA||'-' %>" data-toggle="tooltip"><%= v.EMPRESA||'-' %></div></td>
                      <td class="text-center">
                        <% if (v.NOTEBOOK === 'SIM') { %>
                          <span style="color:<%= v.ITENS_RESERVADOS > 0 ? '#27ae60' : '#e74c3c' %>;" title="<%= v.ITENS_RESERVADOS > 0 ? 'Notebook reservado no estoque' : 'Notebook sem reserva' %>">
                            <i class="fas fa-laptop"></i>
                          </span>
                        <% } else { %>
                          <span style="color:#adb5bd;"><i class="fas fa-times"></i></span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <% if (v.CELULAR === 'SIM') { %>
                          <span style="color:<%= v.ITENS_RESERVADOS > 0 ? '#27ae60' : '#e74c3c' %>;" title="<%= v.ITENS_RESERVADOS > 0 ? 'Celular reservado no estoque' : 'Celular sem reserva' %>">
                            <i class="fas fa-mobile-alt"></i>
                          </span>
                        <% } else { %>
                          <span style="color:#adb5bd;"><i class="fas fa-times"></i></span>
                        <% } %>
                      </td>
                      <td class="req-cell"><div class="cell-inner clickable-cell" title="<%= v.REQUISITOS_VAGA||'-' %>" data-toggle="tooltip"><%= v.REQUISITOS_VAGA||'-' %></div></td>
                      <td>
                        <div class="d-flex justify-content-center flex-wrap" style="gap:.25rem;">
                          <% if (candidaturasFeitas.includes(v.ID)) { %>
                            <span class="badge" style="background:#17a2b8;color:white;font-size:.74rem;padding:4px 7px;"><i class="fas fa-check-circle me-1"></i>Candidatado</span>
                          <% } %>
                          <button class="btn btn-sm btn-outline-info btn-listar-candidatos" data-id="<%= v.ID %>" data-funcao="<%= v.FUNCAO %>" title="Listar candidatos" aria-label="Listar candidatos"><i class="fas fa-users"></i></button>
                          <% if (v.STATUS !== 'FECHADA') { %>
                            <button class="btn btn-sm btn-primary btn-candidatura" data-id="<%= v.ID %>" data-funcao="<%= v.FUNCAO %>" title="Candidatar-se" aria-label="Candidatura"><i class="fas fa-user-plus"></i></button>
                            <button class="btn btn-sm btn-success btn-fechar-vaga" data-id="<%= v.ID %>" title="Fechar Vaga" aria-label="Fechar Vaga"><i class="fas fa-check"></i></button>
                          <% } else { %>
                            <span class="text-muted">-</span>
                          <% } %>
                          <%
                            const precisaEquip = (v.NOTEBOOK === 'SIM' || v.CELULAR === 'SIM');
                            const semReserva = v.ITENS_RESERVADOS === 0;
                            const pedidoPendente = v.PEDIDOS_PENDENTES > 0;
                          %>
                          <% if (precisaEquip && semReserva && v.STATUS !== 'FECHADA') { %>
                            <% if (pedidoPendente) { %>
                              <span class="badge" style="background:#f39c12;color:white;font-size:.72rem;padding:3px 6px;" title="Pedido de compra TI pendente">
                                <i class="fas fa-clock me-1"></i>Pedido TI
                              </span>
                            <% } else { %>
                              <span class="badge" style="background:#e74c3c;color:white;font-size:.72rem;padding:3px 6px;" title="Itens TI necessários sem estoque">
                                <i class="fas fa-exclamation-triangle me-1"></i>Sem Estoque TI
                              </span>
                              <button class="btn btn-sm btn-warning btn-fazer-pedido" style="padding:2px 6px;font-size:.72rem;"
                                data-id="<%= v.ID %>"
                                data-funcao="<%= v.FUNCAO %>"
                                data-setor="<%= v.SETOR||'' %>"
                                data-prazo="<%= v.PRAZO_CONTRATACAO||'' %>"
                                data-solicitante="<%= v.SOLICITANTE||'' %>"
                                data-qtd-notebook="<%= v.NOTEBOOK==='SIM' ? 1 : 0 %>"
                                data-qtd-celular="<%= v.CELULAR==='SIM' ? 1 : 0 %>"
                                title="Fazer pedido de compra TI">
                                <i class="fas fa-shopping-cart"></i>
                              </button>
                            <% } %>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="vagas-grid">
              <% vagas.forEach(v => { %>
                <%
                  const jaCandidatou = (v.ALL_IDS || [v.ID]).some(function(aid) {
                    return candidaturasFeitas.includes(aid);
                  });
                  const totalVagas = v.TOTAL_VAGAS || 1;
                %>
                <div class="vaga-card" data-fulltext="Função: <%= String(v.FUNCAO || '-').replace(/"/g, '&quot;') %>&#10;Vagas abertas: <%= totalVagas %>&#10;Tipo: <%= String(v.TIPO_VAGA || '-').replace(/"/g, '&quot;') %>&#10;Empresa: <%= String(v.EMPRESA || '-').replace(/"/g, '&quot;') %>&#10;Abertura: <%= String(v.DATA_ABERTURA || '-').replace(/"/g, '&quot;') %>&#10;SLA: <%= v.SLA_DIAS !== null ? String(v.SLA_DIAS) : '-' %> dias&#10;&#10;Requisitos:&#10;<%= String(v.REQUISITOS_VAGA || 'Sem requisitos informados.').replace(/"/g, '&quot;') %>">
                  <div class="head">
                    <h5><%= v.FUNCAO %></h5>
                    <div class="d-flex flex-column align-items-end" style="gap:.25rem;">
                      <span class="badge" style="background:#27ae60;color:white;font-size:.78rem;"><%= totalVagas %> vaga<%= totalVagas > 1 ? 's' : '' %></span>
                      <% if(v.CLASSIFICACAO){ %>
                        <span class="badge" style="background:<%= v.CLASSIFICACAO==='ALTA'?'#e74c3c':v.CLASSIFICACAO==='MEDIA'?'#f39c12':'#27ae60' %>;color:white;font-size:.72rem;"><%= v.CLASSIFICACAO %></span>
                      <% } %>
                    </div>
                  </div>
                  <div>
                    <span class="badge" style="background:<%= v.TIPO_VAGA==='INTERNA'?'#2B286F':'#D11F3F' %>;color:white;"><%= v.TIPO_VAGA %></span>
                  </div>
                  <div class="vaga-meta">
                    <span><i class="fas fa-building me-1"></i><%= v.EMPRESA || '-' %></span>
                    <span><i class="fas fa-calendar me-1"></i>Abertura: <%= v.DATA_ABERTURA || '-' %></span>
                    <span><i class="fas fa-hourglass-half me-1"></i>SLA: <%= v.SLA_DIAS !== null ? v.SLA_DIAS : '-' %> dias</span>
                    <span><i class="fas fa-users me-1"></i>Candidatos: <%= v.CANDIDATOS!==null?v.CANDIDATOS:0 %></span>
                  </div>
                  <div class="vaga-requisitos" title="<%= v.REQUISITOS_VAGA || '-' %>"><%= v.REQUISITOS_VAGA || 'Sem requisitos informados.' %></div>
                  <div class="mt-auto pt-2 d-flex flex-column align-items-center">
                    <% if (jaCandidatou) { %>
                      <span style="font-size:.82rem;color:#17a2b8;font-weight:600;" class="mb-2"><i class="fas fa-check-circle me-1"></i>Já me candidatei</span>
                    <% } else { %>
                      <button class="btn btn-primary btn-sm btn-candidatura" data-id="<%= v.ID %>" data-funcao="<%= v.FUNCAO %>">
                        <i class="fas fa-paper-plane me-1"></i>Candidatar-se
                      </button>
                    <% } %>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (isAdmin) { %>
<div class="modal fade" id="modalNovaVaga" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static" data-keyboard="false">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Cadastrar Nova Vaga</h5>
        <button type="button" class="close" data-dismiss="modal" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <form id="formNovaVaga">
          <div class="row">
            <div class="col-12 col-md-3 mb-3"><label>Empresa</label><select id="empresaSelect" name="empresa" class="form-control"></select></div>
            <div class="col-12 col-md-6 mb-3"><label>Função <span class="text-danger">*</span></label><select id="funcaoSelect" name="funcao" class="form-control" required></select></div>
            <div class="col-12 col-md-3 mb-3"><label>Data Abertura <span class="text-danger">*</span></label><input type="date" class="form-control" name="data_abertura" required></div>
          </div>
          <div class="row">
            <div class="col-12 col-md-4 mb-3"><label>Solicitante</label><select id="solicitanteSelect" name="solicitante" class="form-control"></select></div>
            <div class="col-12 col-md-4 mb-3">
              <label>Setor</label>
              <select class="form-control" name="setor">
                <option value="">Selecione...</option>
                <option>FISCAL</option><option>FRETEIRO</option><option>LOGISTICA</option><option>ADM</option><option>FINANCEIRO</option><option>COMERCIAL</option>
                <option>CONTABILIDADE</option><option>TI</option><option>RH</option><option>TST</option><option>COMPRAS</option><option>FATURAMENTO</option>
                <option>MARKETING</option><option>OPERACAO</option><option>SERVICOS</option><option>DIRETORIA</option><option>QUALIDADE</option><option>MANUTENCAO</option>
                <option>PRODUCAO</option><option>FROTA</option><option>ALMOXARIFADO</option><option>ETA</option><option>ETE</option>
              </select>
            </div>
            <div class="col-12 col-md-4 mb-3">
              <label>Tipo de Vaga <span class="text-danger">*</span></label>
              <select class="form-control" name="tipo_vaga" required>
                <option value="">Selecione...</option>
                <option value="INTERNA">INTERNA</option>
                <option value="EXTERNA">EXTERNA</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-12 col-md-3 mb-3"><label>Notebook</label><select class="form-control" name="notebook"><option value="NAO">NÃO</option><option value="SIM">SIM</option></select></div>
            <div class="col-12 col-md-3 mb-3"><label>Celular</label><select class="form-control" name="celular"><option value="NAO">NÃO</option><option value="SIM">SIM</option></select></div>
            <div class="col-12 col-md-3 mb-3"><label>SLA (dias)</label><input type="number" class="form-control" name="sla_dias" id="sla_dias" min="1" readonly style="background:#e9ecef;cursor:not-allowed;"></div>
            <div class="col-12 col-md-3 mb-3"><label>Classificação</label><input type="text" class="form-control" name="classificacao" id="classificacao" readonly style="background:#e9ecef;cursor:not-allowed;"></div>
          </div>
          <div class="mb-3">
            <label>Requisitos da Vaga</label>
            <textarea class="form-control requisitos-textarea" name="requisitos_vaga" rows="3" style="max-height:120px;overflow:auto;resize:vertical;" placeholder="ANALISTA ADM - JR | 1 A 2 ANOS DE EXPERIENCIA - ENSINO SUPERIOR CURSANDO OU COMPLETO - EXCEL INTERMEDIARIO - ROTINAS ADMINISTRATIVAS - ORGANIZACAO E ATENCAO A DETALHES - TRABALHO EM EQUIPE - DISPONIBILIDADE IMEDIATA"></textarea>
          </div>
          <div class="row">
            <div class="col-12 col-md-6 mb-3"><label>Prazo Contratação</label><input type="date" class="form-control" name="prazo_contratacao"></div>
            <div class="col-12 col-md-6 mb-3">
              <label>Status</label>
              <select class="form-control" name="status">
                <option value="ABERTA">ABERTA</option><option value="FECHADA">FECHADA</option><option value="ATRASADA">ATRASADA</option>
              </select>
            </div>
          </div>
          <div id="formError" class="alert alert-danger" style="display:none;"></div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnSalvarVaga" style="background:linear-gradient(135deg,#2B286F 100%);border:none;">
          <span id="savingSpinner" class="spinner-border spinner-border-sm me-1" style="display:none;" role="status"></span>
          <i class="fas fa-save me-1" id="saveIcon"></i>Salvar Vaga
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalFecharVaga" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Fechar Vaga</h5>
        <button type="button" class="close" data-dismiss="modal" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="fecharVagaId">
        <div class="mb-3"><label>Matrícula</label><select id="fecharMatricula" name="fecharMatricula" class="form-control"></select></div>
        <div class="mb-3"><label>Entrevistas</label><input type="number" id="fecharEntrevistas" class="form-control" min="0" placeholder="Ex: 3"></div>
        <div class="mb-3"><label>Data Contratação</label><input type="date" id="fecharDtContratacao" class="form-control"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-success" id="btnFecharVaga">Fechar Vaga</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalPedidoCompra" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static" data-keyboard="false">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header" style="background:linear-gradient(135deg,#e67e22,#D11F3F);">
        <h5 class="modal-title" style="color:white;"><i class="fas fa-exclamation-triangle me-2"></i>Estoque TI Insuficiente</h5>
        <button type="button" class="close" id="btnFecharModalPedido" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning" style="font-size:.9rem;">
          <i class="fas fa-warehouse me-2"></i>Não há itens suficientes no estoque para cobrir esta vaga.
        </div>
        <div id="pedidoItensResumo" class="mb-3"></div>
        <p class="mb-0" style="font-size:.92rem;">Deseja enviar um <strong>pedido de compra</strong> para os responsáveis (TI, Compras, RH)?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" id="btnSkipPedido">
          <i class="fas fa-times me-1"></i>Não, criar vaga mesmo assim
        </button>
        <button type="button" class="btn btn-warning" id="btnConfirmarPedido">
          <span id="pedidoSpinner" class="spinner-border spinner-border-sm me-1" style="display:none;"></span>
          <i class="fas fa-envelope me-1" id="pedidoIcon"></i>Sim, enviar pedido de compra
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalCandidatosVaga" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-xl" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-users me-2"></i><span id="candidatosVagaTitulo">Candidatos da vaga</span></h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body">
        <div id="candidatosLoading" class="text-muted" style="display:none;">Carregando candidatos...</div>
        <div class="table-responsive">
          <table id="tblCandidatosVaga" class="display table table-striped table-hover" style="width:100%">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Celular</th>
                <th>E-mail</th>
                <th>LinkedIn</th>
                <th>Data Inclusão</th>
                <th>Apresentação</th>
                <th>Currículo</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
      </div>
    </div>
  </div>
</div>
<% } %>

<div class="modal fade" id="modalCandidatura" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Candidatura - <span id="candidaturaFuncao"></span></h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <form id="formCandidatura" enctype="multipart/form-data">
          <input type="hidden" id="candidaturaIdVaga" name="id_vaga">
          <div class="row">
            <div class="col-12 col-md-6 mb-3"><label>Nome completo <span class="text-danger">*</span></label><input type="text" class="form-control" name="nome" id="candNome" required></div>
            <div class="col-12 col-md-6 mb-3"><label>Celular <span class="text-danger">*</span></label><input type="tel" class="form-control" name="celular" id="candCelular" maxlength="15" required></div>
          </div>
          <div class="row">
            <div class="col-12 col-md-6 mb-3"><label>E-mail <span class="text-danger">*</span></label><input type="email" class="form-control" name="email" id="candEmail" required></div>
            <div class="col-12 col-md-6 mb-3"><label>LinkedIn <small class="text-muted">(opcional)</small></label><input type="url" class="form-control" name="linkedin" id="candLinkedin"></div>
          </div>
          <div class="mb-3"><label>Apresentação breve <span class="text-danger">*</span></label><textarea class="form-control" name="apresentacao" id="candApresentacao" rows="4" required></textarea></div>
          <div class="row">
            <div class="col-12 col-md-6 mb-3"><label>Link adicional <small class="text-muted">(opcional)</small></label><input type="url" class="form-control" name="link_adicional" id="candLinkAdicional"></div>
            <div class="col-12 col-md-6 mb-3">
              <label>Currículo <small class="text-muted">(PDF, DOC, DOCX, PNG, JPG)</small></label>
              <input type="file" class="form-control" name="curriculo" id="candCurriculo" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg">
              <div id="curriculoPreview" class="mt-2" style="display:none;">
                <div class="d-flex align-items-center p-2 border rounded curriculo-preview-card" style="background:#f8f9fa;">
                  <i class="fas fa-file-alt fa-2x text-primary"></i>
                  <div class="curriculo-preview-meta">
                    <div id="curriculoNome" style="font-weight:500;font-size:.85rem;"></div>
                    <div id="curriculoTamanho" style="font-size:.75rem;color:#6c757d;"></div>
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-danger" id="removerCurriculo"><i class="fas fa-times"></i></button>
                </div>
              </div>
            </div>
          </div>
          <div id="candFormError" class="alert alert-danger" style="display:none;"></div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnSalvarCandidatura">
          <span id="candSpinner" class="spinner-border spinner-border-sm me-1" style="display:none;"></span>
          <i class="fas fa-paper-plane me-1" id="candIcon"></i>Enviar Candidatura
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalCellFull" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Detalhes</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body"><pre id="modalCellFullContent" style="white-space:pre-wrap;word-wrap:break-word;margin:0;"></pre></div>
      <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button></div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function () {
  if (sessionStorage.getItem('candSuccess') === '1') {
    sessionStorage.removeItem('candSuccess');
    $('#candSuccessAlert').show();
    $('html, body').animate({ scrollTop: $('#candSuccessAlert').offset().top - 90 }, 250);
    setTimeout(function() { $('#candSuccessAlert').fadeOut(); }, 4000);
  }

  <% if (isAdmin) { %>
  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function initTabelaCandidatos() {
    if ($.fn.DataTable.isDataTable('#tblCandidatosVaga')) {
      $('#tblCandidatosVaga').DataTable().destroy();
    }

    $('#tblCandidatosVaga').DataTable({
      language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
      pageLength: 10,
      order: [[4, 'desc']],
      initComplete: function() {
        dtBuildFilters(this.api(), 'tblCandidatosVaga_filter', [
          { idx: 0, label: 'Nome...', w: '170px' },
          { idx: 2, label: 'E-mail...', w: '190px' },
          { idx: 4, label: 'Data...', w: '130px' }
        ]);
      }
    });
  }

  function carregarCandidatosDaVaga(idVaga, funcaoVaga) {
    $('#candidatosVagaTitulo').text('Candidatos - ' + (funcaoVaga || 'Vaga #' + idVaga));
    $('#candidatosLoading').show();
    $('#tblCandidatosVaga tbody').html('');
    $('#modalCandidatosVaga').modal('show');

    $.ajax({
      url: '/api/candidaturas/por-funcao',
      method: 'GET',
      data: { funcao: funcaoVaga || '' },
      success: function(rows) {
        var html = '';
        (rows || []).forEach(function(c) {
          var curriculoBtn = c.CURRICULO_PATH
            ? '<div class="d-flex justify-content-center" style="gap:.25rem;"><a href="/api/candidaturas/' + c.ID + '/curriculo" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary btn-curriculo-acao" title="Ver currículo"><i class="fas fa-file-pdf me-1"></i>Ver</a><a href="/api/candidaturas/' + c.ID + '/curriculo?download=1" class="btn btn-sm btn-outline-secondary btn-curriculo-acao" title="Baixar currículo"><i class="fas fa-download me-1"></i>Baixar</a></div>'
            : '<button class="btn btn-sm btn-outline-secondary" disabled>Sem arquivo</button>';
          html += '<tr>' +
            '<td><span class="clickable-cell" title="' + escapeHtml(c.NOME || '-') + '" data-toggle="tooltip">' + escapeHtml(c.NOME || '-') + '</span></td>' +
            '<td><span class="clickable-cell" title="' + escapeHtml(c.CELULAR || '-') + '" data-toggle="tooltip">' + escapeHtml(c.CELULAR || '-') + '</span></td>' +
            '<td><span class="clickable-cell" title="' + escapeHtml(c.EMAIL || '-') + '" data-toggle="tooltip">' + escapeHtml(c.EMAIL || '-') + '</span></td>' +
            '<td><span class="clickable-cell" title="' + escapeHtml(c.LINKEDIN || '-') + '" data-toggle="tooltip">' + escapeHtml(c.LINKEDIN || '-') + '</span></td>' +
            '<td><span class="clickable-cell" title="' + escapeHtml(c.DTINCLUSAO || '-') + '" data-toggle="tooltip">' + escapeHtml(c.DTINCLUSAO || '-') + '</span></td>' +
            '<td style="max-width:200px;">' +
              (function() {
                var apres = c.APRESENTACAO || '-';
                var apresShort = apres.length > 90 ? apres.substring(0, 90) + '…' : apres;
                return '<span class="cand-apresentacao" style="cursor:pointer;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-size:.82rem;line-height:1.3;" ' +
                  'data-fulltext="' + escapeHtml(apres) + '" title="Clique para ver completo">' +
                  escapeHtml(apresShort) + '</span>';
              })() +
            '</td>' +
            '<td class="text-center">' + curriculoBtn + '</td>' +
          '</tr>';
        });
        if (!html) {
          html = '<tr><td colspan="7" class="text-center text-muted">Nenhum candidato para esta vaga.</td></tr>';
        }
        $('#tblCandidatosVaga tbody').html(html);
        initTabelaCandidatos();
        $('#candidatosLoading').hide();
        $('body').tooltip({ selector: '[data-toggle="tooltip"]', container: 'body' });
      },
      error: function(xhr) {
        $('#candidatosLoading').hide();
        $('#tblCandidatosVaga tbody').html('<tr><td colspan="7" class="text-center text-danger">' + escapeHtml(xhr.responseJSON?.error || 'Erro ao carregar candidatos.') + '</td></tr>');
      }
    });
  }

  $('#tblVagas').DataTable({
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
    dom: 'Bfrtip',
    buttons: [{ extend:'excelHtml5', text:'<i class="fas fa-file-excel"></i> Excel', className:'btn btn-success btn-sm', title:'Vagas RH' }],
    pageLength: 25,
    order: [[9,'desc']],
    columnDefs: [{ targets:[15], orderable:false }],
    initComplete: function() {
      dtBuildFilters(this.api(), 'tblVagas_filter', [
        {idx:0, label:'Função...', w:'160px'},
        {idx:1, label:'Tipo...', w:'110px'},
        {idx:2, label:'Status...', w:'110px'},
        {idx:3, label:'Setor...', w:'120px'},
        {idx:4, label:'Solicitante...', w:'160px'},
        {idx:9, label:'Abertura...', w:'130px'}
      ]);
    }
  });

  function initSelect2() {
    if (!$('#funcaoSelect').hasClass('select2-hidden-accessible')) {
      $('#funcaoSelect').select2({
        placeholder: 'Selecione ou digite...', allowClear: true,
        dropdownParent: $('#modalNovaVaga'),
        ajax: { url:'/api/funcoes', dataType:'json', delay:250,
          data: function(p){ return { q: p.term || '' }; },
          processResults: function(d){ return { results: d.map(function(f){ return {id:f,text:f}; }) }; }, cache:true }
      });
    }
    if (!$('#solicitanteSelect').hasClass('select2-hidden-accessible')) {
      $('#solicitanteSelect').select2({
        placeholder: 'Selecione ou digite...', allowClear: true,
        dropdownParent: $('#modalNovaVaga'),
        ajax: { url:'/api/pessoas', dataType:'json', delay:250,
          data: function(p){ return { q: p.term || '' }; },
          processResults: function(d){ return { results: d }; }, cache:true }
      });
    }
  }

  $('#modalNovaVaga').on('shown.bs.modal', initSelect2);

  if (!$('#empresaSelect').hasClass('select2-hidden-accessible')) {
    $('#empresaSelect').select2({
      placeholder: 'Selecione ou digite...', allowClear: true,
      dropdownParent: $('#modalNovaVaga'),
      ajax: { url:'/api/empresas', dataType:'json', delay:250,
        data: function(p){ return { q: p.term || '' }; },
        processResults: function(d){ return { results: d }; }, cache:true }
    });
  }

  if (!$('#fecharMatricula').hasClass('select2-hidden-accessible')) {
    $('#fecharMatricula').select2({
      placeholder: 'Selecione ou digite...', allowClear: true,
      dropdownParent: $('#modalFecharVaga'),
      ajax: { url:'/api/matriculas', dataType:'json', delay:250,
        data: function(p){ return { q: p.term || '' }; },
        processResults: function(d){ return { results: d }; }, cache:true }
    });
  }

  if (!$('select[name="setor"]').hasClass('select2-hidden-accessible')) {
    $('select[name="setor"]').select2({ placeholder: 'Selecione ou digite...', allowClear: true, dropdownParent: $('#modalNovaVaga') });
  }

  $('#funcaoSelect').on('change select2:select', function() {
    const funcao = $(this).val();
    if (!funcao) return;
    $.getJSON('/api/sla/by-funcao', { funcao: funcao }, function(d) {
      if (d.sla_dias !== undefined) $('#sla_dias').val(d.sla_dias);
      if (d.classificacao) $('#classificacao').val(d.classificacao);
    });
  });

  var _pedidoPendente = null; // armazena contexto do pedido durante o fluxo

  $('#btnNovaVaga').on('click', function() {
    $('#formNovaVaga')[0].reset();
    $('#formError').hide();
    $('#funcaoSelect').val(null).trigger('change');
    $('#solicitanteSelect').val(null).trigger('change');
    $('#empresaSelect').val(null).trigger('change');
    $('[name="data_abertura"]').val(new Date().toISOString().split('T')[0]);
    $('[name="tipo_vaga"]').val('EXTERNA');
    $('[name="notebook"]').val('NAO');
    $('[name="celular"]').val('NAO');
    $('#modalNovaVaga').modal('show');
  });

  function salvarVagaComDados(data, fazerPedido) {
    $('#savingSpinner').show();
    $('#saveIcon').hide();
    $('#btnSalvarVaga').prop('disabled', true);

    $.ajax({
      url: '/vagas', method: 'POST', contentType: 'application/json', data: JSON.stringify(data),
      success: function(resp) {
        var vagaId = resp.id;
        if (fazerPedido && vagaId) {
          var itens = [];
          if (data.notebook === 'SIM') itens.push({ tipo: 'NOTEBOOK', qtd: 1 });
          if (data.celular === 'SIM') itens.push({ tipo: 'CELULAR', qtd: 1 });
          $('#pedidoSpinner').show(); $('#pedidoIcon').hide();
          $.ajax({
            url: '/api/estoque/pedido', method: 'POST', contentType: 'application/json',
            data: JSON.stringify({
              id_vaga: vagaId, itens: itens,
              funcao: data.funcao, setor: data.setor,
              prazo: data.prazo_contratacao, solicitante: data.solicitante
            }),
            complete: function() { location.reload(); }
          });
        } else {
          location.reload();
        }
      },
      error: function(xhr) {
        $('#formError').text(xhr.responseJSON?.error || 'Erro ao salvar.').show();
        $('#modalNovaVaga').modal('show');
        $('#savingSpinner').hide();
        $('#saveIcon').show();
        $('#btnSalvarVaga').prop('disabled', false);
      }
    });
  }

  $('#btnSalvarVaga').on('click', function() {
    if (!$('#funcaoSelect').val()) { $('#formError').text('Selecione a função.').show(); return; }
    const form = document.getElementById('formNovaVaga');
    if (!form.checkValidity()) { form.reportValidity(); return; }

    const data = {};
    $(form).serializeArray().forEach(function(f) { data[f.name] = f.value; });
    const needsNb = data.notebook === 'SIM' ? 1 : 0;
    const needsCel = data.celular === 'SIM' ? 1 : 0;

    if (needsNb > 0 || needsCel > 0) {
      $.ajax({
        url: '/api/estoque/verificar', method: 'GET', data: { notebook: needsNb, celular: needsCel },
        success: function(result) {
          if (result.disponivel) {
            salvarVagaComDados(data, false);
          } else {
            _pedidoPendente = { vagaData: data, estoqueResult: result };
            var html = '<ul style="margin:0;">';
            if (result.faltaNb > 0) html += '<li><i class="fas fa-laptop me-1"></i><strong>Notebook:</strong> disponível ' + result.dispNb + ', falta <strong>1</strong></li>';
            if (result.faltaCel > 0) html += '<li><i class="fas fa-mobile-alt me-1"></i><strong>Celular:</strong> disponível ' + result.dispCel + ', falta <strong>1</strong></li>';
            html += '</ul>';
            $('#pedidoItensResumo').html(html);
            $('#btnConfirmarPedido').prop('disabled', false);
            $('#pedidoSpinner').hide(); $('#pedidoIcon').show();
            $('#modalNovaVaga').modal('hide');
            $('#modalPedidoCompra').modal('show');
          }
        },
        error: function() { salvarVagaComDados(data, false); }
      });
    } else {
      salvarVagaComDados(data, false);
    }
  });

  $('#btnSkipPedido').on('click', function() {
    $('#modalPedidoCompra').modal('hide');
    if (_pedidoPendente && _pedidoPendente.vagaData) {
      salvarVagaComDados(_pedidoPendente.vagaData, false);
      _pedidoPendente = null;
    }
  });

  $('#btnFecharModalPedido').on('click', function() {
    $('#modalPedidoCompra').modal('hide');
    if (_pedidoPendente && _pedidoPendente.vagaData) {
      $('#modalNovaVaga').modal('show');
    }
    if (_pedidoPendente && _pedidoPendente.vagaId) {
      _pedidoPendente = null;
    }
  });

  $('#btnConfirmarPedido').on('click', function() {
    if (!_pedidoPendente) return;
    $('#btnConfirmarPedido').prop('disabled', true);
    $('#pedidoSpinner').show(); $('#pedidoIcon').hide();

    if (_pedidoPendente.vagaData) {
      // Fluxo da nova vaga: salvar + fazer pedido
      salvarVagaComDados(_pedidoPendente.vagaData, true);
      _pedidoPendente = null;
    } else if (_pedidoPendente.vagaId) {
      // Fluxo de vaga existente: só fazer pedido
      var itens = [];
      if (_pedidoPendente.qtdNb > 0) itens.push({ tipo: 'NOTEBOOK', qtd: _pedidoPendente.qtdNb });
      if (_pedidoPendente.qtdCel > 0) itens.push({ tipo: 'CELULAR', qtd: _pedidoPendente.qtdCel });
      $.ajax({
        url: '/api/estoque/pedido', method: 'POST', contentType: 'application/json',
        data: JSON.stringify({
          id_vaga: _pedidoPendente.vagaId, itens: itens,
          funcao: _pedidoPendente.funcao, setor: _pedidoPendente.setor,
          prazo: _pedidoPendente.prazo, solicitante: _pedidoPendente.solicitante
        }),
        success: function() { _pedidoPendente = null; location.reload(); },
        error: function(xhr) {
          alert(xhr.responseJSON?.error || 'Erro ao enviar pedido.');
          $('#btnConfirmarPedido').prop('disabled', false);
          $('#pedidoSpinner').hide(); $('#pedidoIcon').show();
        }
      });
    }
  });

  // Botão "Fazer Pedido" nas vagas existentes sem estoque
  $(document).on('click', '.btn-fazer-pedido', function() {
    var btn = $(this);
    var qtdNb = parseInt(btn.data('qtd-notebook')) || 0;
    var qtdCel = parseInt(btn.data('qtd-celular')) || 0;

    _pedidoPendente = {
      vagaId: btn.data('id'),
      funcao: btn.data('funcao'),
      setor: btn.data('setor'),
      prazo: btn.data('prazo'),
      solicitante: btn.data('solicitante'),
      qtdNb: qtdNb,
      qtdCel: qtdCel,
    };

    var html = '<ul style="margin:0;">';
    if (qtdNb > 0) html += '<li><i class="fas fa-laptop me-1"></i><strong>Notebook:</strong> ' + qtdNb + ' unidade(s)</li>';
    if (qtdCel > 0) html += '<li><i class="fas fa-mobile-alt me-1"></i><strong>Celular:</strong> ' + qtdCel + ' unidade(s)</li>';
    html += '</ul>';
    $('#pedidoItensResumo').html(html);
    $('#btnConfirmarPedido').prop('disabled', false);
    $('#pedidoSpinner').hide(); $('#pedidoIcon').show();
    $('#modalPedidoCompra').modal('show');
  });

  $(document).on('click', '.btn-fechar-vaga', function() {
    const id = $(this).data('id');
    const today = new Date().toISOString().split('T')[0];
    $('#fecharVagaId').val(id);
    $('#fecharMatricula').val(null).trigger('change');
    $('#fecharEntrevistas').val('');
    $('#fecharDtContratacao').val(today);
    $('#modalFecharVaga').modal('show');
  });

  $('#btnFecharVaga').on('click', function() {
    const id = $('#fecharVagaId').val();
    if (!id) return alert('ID da vaga não encontrado.');

    const data = {
      matricula: $('#fecharMatricula').val(),
      entrevistas: $('#fecharEntrevistas').val(),
      dt_contratacao: $('#fecharDtContratacao').val()
    };

    $.ajax({
      url:'/vagas/fechar/' + id,
      method:'PUT',
      contentType:'application/json',
      data: JSON.stringify(data),
      success: function() { $('#modalFecharVaga').modal('hide'); location.reload(); },
      error: function(xhr) { alert(xhr.responseJSON?.error || 'Erro ao fechar vaga.'); }
    });
  });

  $(document).on('click', '.btn-listar-candidatos', function() {
    const id = $(this).data('id');
    const funcao = $(this).data('funcao');
    carregarCandidatosDaVaga(id, funcao);
  });

  $('#modalCandidatosVaga').on('hidden.bs.modal', function() {
    if ($.fn.DataTable.isDataTable('#tblCandidatosVaga')) {
      $('#tblCandidatosVaga').DataTable().destroy();
    }
    $('#tblCandidatosVaga tbody').empty();
  });

  $(document).on('click', '.cand-apresentacao', function() {
    var full = $(this).data('fulltext') || $(this).text();
    if (full && full.trim() !== '-') {
      $('#modalCellFullContent').text(full.trim());
      $('#modalCellFull').modal('show');
    }
  });
  <% } %>

  $('body').tooltip({ selector: '[data-toggle="tooltip"]', container: 'body' });

  $('#tblVagas').on('click', '.clickable-cell', function() {
    const fullText = $(this).attr('data-original-title') || $(this).attr('title') || $(this).text();
    if (fullText && fullText.trim() !== '-' && fullText.trim() !== '') {
      try { $(this).tooltip('hide'); } catch (e) {}
      $('#modalCellFullContent').text(fullText.trim());
      $('#modalCellFull').modal('show');
    }
  });

  $('#modalCellFull').on('hidden.bs.modal', function () { $('#modalCellFullContent').text(''); });

  $(document).on('click', '.vaga-card', function() {
    var fullText = $(this).attr('data-fulltext') || '';
    if (!fullText.trim()) return;
    $('#modalCellFullContent').text(fullText.replace(/&#10;/g, '\n'));
    $('#modalCellFull').modal('show');
  });

  $(document).on('click', '.vaga-card .btn', function(event) {
    event.stopPropagation();
  });

  $(document).on('click', '.btn-candidatura', function() {
    const id = $(this).data('id');
    const funcao = $(this).data('funcao');
    $('#candidaturaIdVaga').val(id);
    $('#candidaturaFuncao').text(funcao);
    $('#formCandidatura')[0].reset();
    $('#curriculoPreview').hide();
    $('#candFormError').hide();
    $('#modalCandidatura').modal('show');
  });

  $('#candCelular').on('input', function() {
    let v = $(this).val().replace(/\D/g, '').substring(0, 11);
    if (v.length >= 7) v = '(' + v.substring(0,2) + ') ' + v.substring(2,7) + '-' + v.substring(7);
    else if (v.length >= 3) v = '(' + v.substring(0,2) + ') ' + v.substring(2);
    else if (v.length > 0) v = '(' + v;
    $(this).val(v);
  });

  $('#candCurriculo').on('change', function() {
    const file = this.files[0];
    if (file) {
      $('#curriculoNome').text(file.name);
      $('#curriculoTamanho').text((file.size / 1024 / 1024).toFixed(2) + ' MB');
      $('#curriculoPreview').show();
    } else {
      $('#curriculoPreview').hide();
    }
  });

  $('#removerCurriculo').on('click', function() {
    $('#candCurriculo').val('');
    $('#curriculoPreview').hide();
  });

  $('#btnSalvarCandidatura').on('click', function() {
    const nome = $('#candNome').val().trim();
    const celular = $('#candCelular').val().trim();
    const email = $('#candEmail').val().trim();
    const apresentacao = $('#candApresentacao').val().trim();

    if (!nome || !celular || !email || !apresentacao) {
      $('#candFormError').text('Preencha todos os campos obrigatórios.').show();
      return;
    }

    if (!email.includes('@') || !email.includes('.')) {
      $('#candFormError').text('E-mail inválido.').show();
      return;
    }

    const formData = new FormData(document.getElementById('formCandidatura'));

    $('#candSpinner').show();
    $('#candIcon').hide();
    $('#btnSalvarCandidatura').prop('disabled', true);

    $.ajax({
      url: '/api/candidatura',
      method: 'POST',
      data: formData,
      processData: false,
      contentType: false,
      success: function() {
        $('#modalCandidatura').modal('hide');
        sessionStorage.setItem('candSuccess', '1');
        location.reload();
      },
      error: function(xhr) {
        $('#candFormError').text(xhr.responseJSON?.error || 'Erro ao enviar.').show();
        $('#candSpinner').hide();
        $('#candIcon').show();
        $('#btnSalvarCandidatura').prop('disabled', false);
      }
    });
  });
});
</script>
</body>
</html>
