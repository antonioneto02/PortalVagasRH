<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Estoque TI - Portal Vagas RH</title>
  <%- include('../System/headIncludes.ejs') %>
  <style>
    .me-1{margin-right:.25rem!important;}.me-2{margin-right:.5rem!important;}
    #tblEstoque td,#tblPedidos td{vertical-align:middle;}
    .status-badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:.74rem;color:white;font-weight:600;}
    .badge-disponivel{background:#27ae60;}
    .badge-reservado{background:#2B286F;}
    .badge-em_uso{background:#17a2b8;}
    .badge-manutencao{background:#e67e22;}
    .badge-pendente{background:#f39c12;}
    .badge-atendido{background:#27ae60;}
    .badge-cancelado{background:#6c757d;}
.nav-tabs .nav-link{color:#2B286F;font-weight:500;}
    .nav-tabs .nav-link.active{color:#D11F3F;border-color:#dee2e6 #dee2e6 #fff;font-weight:700;}
    .dt-filtros select{font-size:.82rem;height:calc(1.5em + .5rem + 2px);display:inline-block;width:auto;min-width:110px;}
  </style>
</head>
<body>
<div class="layout-container">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <h1><i class="bi bi-laptop me-2"></i>Estoque TI</h1>
      </div>
      <div class="topbar-right">
        <span><i class="bi bi-person-circle me-1"></i><%= username %></span>
        <a href="/logout"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
      </div>
    </div>

    <div class="content">

      <%
        const countDisp = itens.filter(i => i.STATUS === 'DISPONIVEL').length;
        const countRes  = itens.filter(i => i.STATUS === 'RESERVADO').length;
        const countUso  = itens.filter(i => i.STATUS === 'EM_USO').length;
        const countMan  = itens.filter(i => i.STATUS === 'MANUTENCAO').length;
        const countPedPend = pedidos.filter(p => p.STATUS === 'PENDENTE').length;
      %>

      <div class="indicators-bar">
        <div class="indicator-card" style="background:#27ae60;"><div class="indicator-val"><%= countDisp %></div><div class="indicator-lbl">Disponível</div></div>
        <div class="indicator-card" style="background:#2B286F;"><div class="indicator-val"><%= countRes %></div><div class="indicator-lbl">Reservado</div></div>
        <div class="indicator-card" style="background:#17a2b8;"><div class="indicator-val"><%= countUso %></div><div class="indicator-lbl">Em Uso</div></div>
        <div class="indicator-card" style="background:#e67e22;"><div class="indicator-val"><%= countMan %></div><div class="indicator-lbl">Manutenção</div></div>
        <div class="indicator-card" style="background:#f39c12;"><div class="indicator-val"><%= countPedPend %></div><div class="indicator-lbl">Pedidos Pend.</div></div>
      </div>

      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="mb-0"><i class="bi bi-laptop me-2"></i>Controle de Estoque TI</h4>
          <button class="btn btn-sm" id="btnNovoItem" style="background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.4);color:white;">
            <i class="fas fa-plus me-1"></i> Novo Item
          </button>
        </div>
        <div class="card-body">
          <ul class="nav nav-tabs mb-3" id="estoqueTab">
            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#tabItens"><i class="fas fa-boxes me-1"></i>Itens no Estoque</a></li>
            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#tabPedidos"><i class="fas fa-shopping-cart me-1"></i>Pedidos de Compra <% if(countPedPend > 0){ %><span class="badge badge-warning ml-1"><%= countPedPend %></span><% } %></a></li>
          </ul>

          <div class="tab-content">
            <div class="tab-pane fade show active" id="tabItens">
              <div class="table-responsive">
                <table id="tblEstoque" class="display table table-striped table-hover" style="width:100%">
                  <thead>
                    <tr>
                      <th>ID</th><th>Tipo</th><th>Descrição</th><th>Modelo</th><th class="text-center">Qtd.</th>
                      <th>Status</th><th>Cadastrado</th><th>Ações</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itens.forEach(function(item) { %>
                      <%
                        const statusClass = {
                          'DISPONIVEL':'disponivel','RESERVADO':'reservado',
                          'EM_USO':'em_uso','MANUTENCAO':'manutencao'
                        }[item.STATUS] || 'disponivel';
                        const statusLabel = {
                          'DISPONIVEL':'Disponível','RESERVADO':'Reservado',
                          'EM_USO':'Em Uso','MANUTENCAO':'Manutenção'
                        }[item.STATUS] || item.STATUS;
                      %>
                      <tr>
                        <td><%= item.ID %></td>
                        <td>
                          <span class="badge" style="background:<%= item.TIPO_PRODUTO==='NOTEBOOK'?'#2B286F':'#D11F3F' %>;color:white;padding:3px 8px;border-radius:4px;font-size:.74rem;">
                            <i class="fas fa-<%= item.TIPO_PRODUTO==='NOTEBOOK'?'laptop':'mobile-alt' %> me-1"></i><%= item.TIPO_PRODUTO %>
                          </span>
                        </td>
                        <td><%= item.DESCRICAO || '-' %></td>
                        <td><%= item.MODELO || '-' %></td>
                        <td class="text-center"><strong style="font-size:1rem;color:<%= (item.QUANTIDADE||1) > 0 ? '#27ae60' : '#e74c3c' %>"><%= item.QUANTIDADE || 1 %></strong></td>
                        <td><span class="status-badge badge-<%= statusClass %>"><%= statusLabel %></span></td>
                        <td><%= item.DTINCLUSAO || '-' %></td>
                        <td>
                          <div class="d-flex flex-wrap" style="gap:.25rem;">
                            <button class="btn btn-sm btn-outline-primary btn-editar-item" style="padding:2px 7px;"
                              data-id="<%= item.ID %>" data-tipo="<%= item.TIPO_PRODUTO %>"
                              data-desc="<%= item.DESCRICAO||'' %>" data-modelo="<%= item.MODELO||'' %>"
                              data-quantidade="<%= item.QUANTIDADE||1 %>" data-status="<%= item.STATUS %>"
                              title="Editar"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-info btn-ver-itens" style="padding:2px 7px;position:relative;"
                              data-id="<%= item.ID %>"
                              data-desc="<%= (item.DESCRICAO||item.TIPO_PRODUTO) + (item.MODELO ? ' - '+item.MODELO : '') %>"
                              title="Ver alocações">
                              <i class="fas fa-users"></i>
                              <% if ((item.TOTAL_ALOCACOES||0) > 0) { %>
                                <span style="position:absolute;top:-5px;right:-6px;background:#D11F3F;color:white;border-radius:50%;font-size:.6rem;width:16px;height:16px;display:flex;align-items:center;justify-content:center;font-weight:700;"><%= item.TOTAL_ALOCACOES %></span>
                              <% } %>
                            </button>
                            <% if (item.STATUS === 'DISPONIVEL') { %>
                              <button class="btn btn-sm btn-outline-danger btn-excluir-item" style="padding:2px 7px;"
                                data-id="<%= item.ID %>" title="Excluir"><i class="fas fa-trash"></i></button>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tab-pane fade" id="tabPedidos">
              <div class="table-responsive">
                <table id="tblPedidos" class="display table table-striped table-hover" style="width:100%">
                  <thead>
                    <tr>
                      <th>ID</th><th>Vaga</th><th>Setor</th><th>Itens</th><th>Status</th><th>Solicitado por</th><th>Data</th><th>Ações</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% pedidos.forEach(function(p) { %>
                      <%
                        const pedStatusClass = {
                          'PENDENTE':'pendente','ATENDIDO':'atendido','CANCELADO':'cancelado'
                        }[p.STATUS] || 'pendente';
                        let itensJson = [];
                        try { itensJson = JSON.parse(p.ITENS_JSON || '[]'); } catch(e) {}
                        const itensText = itensJson.map(function(i){ return i.qtd + 'x ' + i.tipo; }).join(', ');
                      %>
                      <tr>
                        <td><%= p.ID %></td>
                        <td><% if(p.ID_VAGA){ %><strong>#<%= p.ID_VAGA %></strong><br><small><%= p.VAGA_FUNCAO||'' %></small><% } else { %>-<% } %></td>
                        <td><%= p.VAGA_SETOR || '-' %></td>
                        <td><%= itensText || '-' %></td>
                        <td><span class="status-badge badge-<%= pedStatusClass %>"><%= p.STATUS %></span></td>
                        <td><%= p.USUARIO_PEDIDO || '-' %></td>
                        <td><%= p.DTPEDIDO || '-' %></td>
                        <td>
                          <% if (p.STATUS === 'PENDENTE') { %>
                            <div class="d-flex" style="gap:.25rem;">
                              <button class="btn btn-sm btn-outline-success btn-atender-pedido" style="padding:2px 7px;"
                                data-id="<%= p.ID %>" title="Marcar como Atendido"><i class="fas fa-check"></i></button>
                              <button class="btn btn-sm btn-outline-danger btn-cancelar-pedido" style="padding:2px 7px;"
                                data-id="<%= p.ID %>" title="Cancelar"><i class="fas fa-times"></i></button>
                            </div>
                          <% } else { %><span class="text-muted">-</span><% } %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalItens" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-users me-2"></i>Item — <span id="itensTitulo"></span></h5>
        <button type="button" class="close" data-dismiss="modal" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <div id="itensLoading" class="text-muted mb-2" style="display:none;"><i class="fas fa-spinner fa-spin me-1"></i>Carregando...</div>
        <div class="table-responsive">
          <table class="table table-sm table-striped table-hover" style="width:100%">
            <thead>
              <tr>
                <th>#</th>
                <th>Vaga</th>
                <th>Matrícula</th>
                <th>Usuário</th>
                <th>Área / Setor</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody id="tblItensBody"></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalItem" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalItemLabel"><i class="fas fa-laptop me-2"></i>Item de Estoque TI</h5>
        <button type="button" class="close" data-dismiss="modal" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="itemId">
        <div class="form-group mb-3">
          <label>Tipo de Produto <span class="text-danger">*</span></label>
          <select class="form-control" id="itemTipo">
            <option value="">Selecione...</option>
            <option value="NOTEBOOK">NOTEBOOK</option>
            <option value="CELULAR">CELULAR</option>
            <option value="OUTRO">OUTRO</option>
          </select>
        </div>
        <div class="form-group mb-3"><label>Descrição</label><input type="text" class="form-control" id="itemDesc" placeholder="Ex: Dell Inspiron 15"></div>
        <div class="row">
          <div class="col-8"><div class="form-group mb-3"><label>Modelo</label><input type="text" class="form-control" id="itemModelo" placeholder="Ex: Core i5 8ª Geração"></div></div>
          <div class="col-4"><div class="form-group mb-3"><label>Quantidade <span class="text-danger">*</span></label><input type="number" class="form-control" id="itemQuantidade" min="0" value="1"></div></div>
        </div>
        <div class="form-group mb-3">
          <label>Status</label>
          <select class="form-control" id="itemStatus">
            <option value="DISPONIVEL">Disponível</option>
            <option value="MANUTENCAO">Manutenção</option>
            <option value="EM_USO">Em Uso</option>
          </select>
        </div>
        <div id="itemError" class="alert alert-danger" style="display:none;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnSalvarItem" style="background:linear-gradient(135deg,#2B286F 100%);border:none;">
          <i class="fas fa-save me-1"></i>Salvar
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function () {
  $('#tblEstoque').DataTable({
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
    dom: 'Bfrtip',
    buttons: [{ extend:'excelHtml5', text:'<i class="fas fa-file-excel"></i> Excel', className:'btn btn-success btn-sm', title:'Estoque TI' }],
    pageLength: 25, order: [[0,'desc']],
    columnDefs: [{ targets: [7], orderable: false }],
    initComplete: function() {
      dtBuildFilters(this.api(), 'tblEstoque_filter', [
        { idx: 1, label: 'Tipo...', w: '120px' },
        { idx: 2, label: 'Descrição...', w: '160px' },
        { idx: 5, label: 'Status...', w: '130px' }
      ]);
    }
  });

  $('#tblPedidos').DataTable({
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json' },
    dom: 'Bfrtip',
    buttons: [{ extend:'excelHtml5', text:'<i class="fas fa-file-excel"></i> Excel', className:'btn btn-success btn-sm', title:'Pedidos Compra TI' }],
    pageLength: 25, order: [[0,'desc']],
    columnDefs: [{ targets: [7], orderable: false }]
  });

  $('#btnNovoItem').on('click', function() {
    $('#itemId').val('');
    $('#itemTipo').val('');
    $('#itemDesc').val('');
    $('#itemModelo').val('');
    $('#itemQuantidade').val(1);
    $('#itemStatus').val('DISPONIVEL');
    $('#itemError').hide();
    $('#modalItemLabel').html('<i class="fas fa-plus-circle me-2"></i>Novo Item de Estoque TI');
    $('#modalItem').modal('show');
  });

  $(document).on('click', '.btn-editar-item', function() {
    var btn = $(this);
    $('#itemId').val(btn.data('id'));
    $('#itemTipo').val(btn.data('tipo'));
    $('#itemDesc').val(btn.data('desc'));
    $('#itemModelo').val(btn.data('modelo'));
    $('#itemQuantidade').val(btn.data('quantidade') || 1);
    $('#itemStatus').val(btn.data('status'));
    $('#itemError').hide();
    $('#modalItemLabel').html('<i class="fas fa-edit me-2"></i>Editar Item #' + btn.data('id'));
    $('#modalItem').modal('show');
  });

  $('#btnSalvarItem').on('click', function() {
    var id = $('#itemId').val();
    var tipo = $('#itemTipo').val();
    if (!tipo) { $('#itemError').text('Selecione o tipo de produto.').show(); return; }

    var data = {
      tipo_produto: tipo,
      descricao: $('#itemDesc').val().trim(),
      modelo: $('#itemModelo').val().trim(),
      quantidade: parseInt($('#itemQuantidade').val()) || 1,
      status: $('#itemStatus').val()
    };

    $.ajax({
      url: id ? '/api/estoque/' + id : '/api/estoque',
      method: id ? 'PUT' : 'POST',
      contentType: 'application/json',
      data: JSON.stringify(data),
      success: function() { location.reload(); },
      error: function(xhr) { $('#itemError').text(xhr.responseJSON?.error || 'Erro ao salvar.').show(); }
    });
  });

  $(document).on('click', '.btn-ver-itens', function() {
    var id   = $(this).data('id');
    var desc = $(this).data('desc') || 'Item #' + id;
    $('#itensTitulo').text(desc);
    $('#tblItensBody').html('');
    $('#itensLoading').show();
    $('#modalItens').modal('show');

    $.ajax({
      url: '/api/estoque/' + id + '/itens',
      method: 'GET',
      success: function(rows) {
        $('#itensLoading').hide();
        if (!rows || !rows.length) {
          $('#tblItensBody').html('<tr><td colspan="5" class="text-center text-muted py-3"><i class="fas fa-inbox me-2"></i>Nenhuma alocação registrada para este item.</td></tr>');
          return;
        }
        var html = '';
        rows.forEach(function(r) {
          html += '<tr>' +
            '<td>' + r.ID + '</td>' +
            '<td><strong>#' + r.ID_VAGA + '</strong>' + (r.VAGA_FUNCAO ? ' — ' + r.VAGA_FUNCAO : '') + '</td>' +
            '<td>' + (r.MATRICULA || '<span class="text-muted">—</span>') + '</td>' +
            '<td>' + (r.USUARIO || '<span class="text-muted">—</span>') + '</td>' +
            '<td>' + (r.AREA || '<span class="text-muted">—</span>') + '</td>' +
            '<td>' + (r.DTALOCACAO || '—') + '</td>' +
            '</tr>';
        });
        $('#tblItensBody').html(html);
      },
      error: function() {
        $('#itensLoading').hide();
        $('#tblItensBody').html('<tr><td colspan="5" class="text-center text-danger">Erro ao carregar alocações.</td></tr>');
      }
    });
  });

  $(document).on('click', '.btn-excluir-item', function() {
    var id = $(this).data('id');
    if (!confirm('Confirma a exclusão deste item?')) return;
    $.ajax({
      url: '/api/estoque/' + id, method: 'DELETE',
      success: function() { location.reload(); },
      error: function(xhr) { alert(xhr.responseJSON?.error || 'Erro ao excluir.'); }
    });
  });

  $(document).on('click', '.btn-atender-pedido', function() {
    var id = $(this).data('id');
    if (!confirm('Marcar pedido #' + id + ' como Atendido?')) return;
    $.ajax({
      url: '/api/estoque/pedidos/' + id + '/status', method: 'PUT',
      contentType: 'application/json', data: JSON.stringify({ status: 'ATENDIDO' }),
      success: function() { location.reload(); },
      error: function(xhr) { alert(xhr.responseJSON?.error || 'Erro ao atualizar pedido.'); }
    });
  });

  $(document).on('click', '.btn-cancelar-pedido', function() {
    var id = $(this).data('id');
    if (!confirm('Cancelar pedido #' + id + '?')) return;
    $.ajax({
      url: '/api/estoque/pedidos/' + id + '/status', method: 'PUT',
      contentType: 'application/json', data: JSON.stringify({ status: 'CANCELADO' }),
      success: function() { location.reload(); },
      error: function(xhr) { alert(xhr.responseJSON?.error || 'Erro ao cancelar pedido.'); }
    });
  });
});
</script>
</body>
</html>
