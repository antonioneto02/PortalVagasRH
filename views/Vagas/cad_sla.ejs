<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>CAD SLA - Portal Vagas RH</title>
  <%- include('../System/headIncludes.ejs') %>
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <style>#tblSla td{vertical-align:middle;}.badge-alta{background:#e74c3c;color:white;padding:3px 8px;border-radius:4px;font-size:.74rem;}.badge-media{background:#f39c12;color:white;padding:3px 8px;border-radius:4px;font-size:.74rem;}.badge-baixa{background:#27ae60;color:white;padding:3px 8px;border-radius:4px;font-size:.74rem;}.me-1{margin-right:.25rem!important;}.me-2{margin-right:.5rem!important;}
  .dt-filtros select{font-size:.82rem;height:calc(1.5em + .5rem + 2px);display:inline-block;width:auto;min-width:110px;}</style>
</head>
<body>
<div class="layout-container">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <h1><i class="bi bi-stopwatch me-2"></i>CAD SLA</h1>
      </div>
      <div class="topbar-right">
        <span><i class="bi bi-person-circle me-1"></i><%= username %></span>
        <a href="/logout"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
      </div>
    </div>

    <div class="content">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="mb-0"><i class="fas fa-stopwatch me-2"></i>Configuração de SLA</h4>
          <% if (podeCadastrar) { %>
            <button class="btn btn-sm" id="btnNovoSla" style="background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.4);color:white;">
              <i class="fas fa-plus me-1"></i> Novo
            </button>
          <% } %>
        </div>
        <div class="card-body">
          <table id="tblSla" class="display table table-striped table-hover" style="width:100%">
            <thead>
              <tr>
                <th>Função</th><th>SLA (dias)</th><th>Classificação</th>
                <% if (podeCadastrar) { %><th style="width:90px;">Ações</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% slaConfig.forEach(s => { %>
                <tr>
                  <td><%= s.FUNCAO %></td>
                  <td><%= s.SLA_DIAS %></td>
                  <td><span class="badge-<%= s.CLASSIFICACAO==='ALTA'?'alta':s.CLASSIFICACAO==='MEDIA'?'media':'baixa' %>"><%= s.CLASSIFICACAO %></span></td>
                  <% if (podeCadastrar) { %>
                    <td>
                      <button class="btn btn-sm btn-outline-primary btn-editar" style="padding:2px 7px;" data-id="<%= s.ID %>" data-funcao="<%= s.FUNCAO %>" data-sla="<%= s.SLA_DIAS %>" data-class="<%= s.CLASSIFICACAO %>"><i class="fas fa-edit"></i></button>
                      <button class="btn btn-sm btn-outline-danger btn-deletar" style="padding:2px 7px;" data-id="<%= s.ID %>"><i class="fas fa-trash"></i></button>
                    </td>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (podeCadastrar) { %>
<div class="modal fade" id="modalSla" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalSlaLabel"><i class="fas fa-stopwatch me-2"></i>SLA</h5>
        <button type="button" class="close" data-dismiss="modal" style="color:white;opacity:1;"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="slaId">
        <div class="form-group mb-3"><label>Função <span class="text-danger">*</span></label><input type="text" class="form-control" id="slaFuncao" placeholder="Ex: ANALISTA ADM - JR"></div>
        <div class="form-group mb-3"><label>SLA (dias) <span class="text-danger">*</span></label><input type="number" class="form-control" id="slaDias" min="1"></div>
        <div class="form-group mb-3">
          <label>Classificação <span class="text-danger">*</span></label>
          <select class="form-control" id="slaClass"><option value="">Selecione...</option><option value="ALTA">ALTA</option><option value="MEDIA">MEDIA</option><option value="BAIXA">BAIXA</option></select>
        </div>
        <div id="slaError" class="alert alert-danger" style="display:none;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnSalvarSla" style="background:linear-gradient(135deg,#2B286F 100%);border:none;"><i class="fas fa-save me-1"></i>Salvar</button>
      </div>
    </div>
  </div>
</div>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function () {
  $('#tblSla').DataTable({
    language:{url:'https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json'},
    dom:'Bfrtip', buttons:[{extend:'excelHtml5',text:'<i class="fas fa-file-excel"></i> Excel',className:'btn btn-success btn-sm',title:'CAD SLA'}],
    pageLength:50, order:[[0,'asc']],
    initComplete: function() {
      var api = this.api();
      var cols = [
        {idx:0, label:'Função...', w:'160px'},
        {idx:1, label:'SLA...', w:'100px'},
        {idx:2, label:'Classificação...', w:'140px'}
      ];
      var filterDiv = $('#tblSla_filter').css({display:'flex', flexWrap:'wrap', alignItems:'center', gap:'.4rem'});
      filterDiv.find('label').css({marginBottom:0, marginRight:'.25rem'});
      cols.forEach(function(c) {
        var col = api.column(c.idx);
        var sel = $('<select style="min-width:'+c.w+';width:'+c.w+';"><option value="">'+c.label+'</option></select>');
        var vals = [];
        col.nodes().each(function() { var t=$(this).text().trim(); if(t&&t!=='-'&&vals.indexOf(t)===-1) vals.push(t); });
        vals.sort().forEach(function(v){sel.append('<option value="'+v+'">'+v+'</option>');});
        filterDiv.append(sel);
        sel.select2({allowClear:true, placeholder:c.label, width:c.w});
        sel.on('change',function(){var v=$(this).val();col.search(v?'^'+$.fn.dataTable.util.escapeRegex(v)+'$':'',true,false).draw();});
      });
    }
  });
  <% if (podeCadastrar) { %>
  $('#btnNovoSla').on('click', function() {
    $('#slaId').val(''); $('#slaFuncao').val(''); $('#slaDias').val(''); $('#slaClass').val('');
    $('#slaError').hide(); $('#modalSlaLabel').html('<i class="fas fa-plus-circle me-2"></i>Novo SLA');
    $('#modalSla').modal('show');
  });
  $(document).on('click', '.btn-editar', function() {
    $('#slaId').val($(this).data('id')); $('#slaFuncao').val($(this).data('funcao'));
    $('#slaDias').val($(this).data('sla')); $('#slaClass').val($(this).data('class'));
    $('#slaError').hide(); $('#modalSlaLabel').html('<i class="fas fa-edit me-2"></i>Editar SLA');
    $('#modalSla').modal('show');
  });
  $('#btnSalvarSla').on('click', function() {
    const id = $('#slaId').val(), funcao=$('#slaFuncao').val().trim(), sla_dias=$('#slaDias').val(), classificacao=$('#slaClass').val();
    if (!funcao||!sla_dias||!classificacao){$('#slaError').text('Preencha todos os campos.').show();return;}
    $.ajax({ url: id?'/api/sla/'+id:'/api/sla', method:id?'PUT':'POST', contentType:'application/json',
      data:JSON.stringify({funcao,sla_dias,classificacao}),
      success(){ location.reload(); },
      error(xhr){ $('#slaError').text(xhr.responseJSON?.error||'Erro ao salvar.').show(); }
    });
  });
  $(document).on('click', '.btn-deletar', function() {
    if (!confirm('Confirma exclusão?')) return;
    $.ajax({ url:'/api/sla/'+$(this).data('id'), method:'DELETE',
      success(){ location.reload(); }, error(){ alert('Erro ao excluir.'); }
    });
  });
  <% } %>
});
</script>
</body>
</html>
